{
  "name": "animalmate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.rls.config.ts --passWithNoTests",
    "test:e2e": "vitest run --config vitest.rls.config.ts test/e2e-http.test.ts",
    "eval": "cross-env RUN_EVAL=1 vitest run --config vitest.rls.config.ts test/chatbot-eval.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.4",
    "next": "^15.1.6",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.5.4",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.2",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
