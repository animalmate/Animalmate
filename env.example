# 환경 변수 예시 — 02-TECH-STACK.md §6 과 동기화할 것.
# 실제 값은 .env(커밋 금지)에 넣는다. service role / API 키 / 시크릿은 서버 전용.

# 앱
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용 — 브라우저에 노출 금지
# Postgres 연결 문자열(서버 전용). Supabase 대시보드 > Project Settings > Database > Connection string.
# 비밀번호에 특수문자가 있으면 URL 인코딩(예: ! → %21).
# 런타임(서버리스) 쿼리 = 트랜잭션 풀러(6543, pgbouncer). 커넥션 폭주 방지.
DATABASE_URL=                       # postgresql://postgres.<ref>:<pw>@...pooler.supabase.com:6543/postgres?pgbouncer=true
# 마이그레이션(DDL) 전용 = 세션 풀러(5432). 트랜잭션 풀러(6543)는 DDL 부적합.
DIRECT_URL=                         # postgresql://postgres.<ref>:<pw>@...pooler.supabase.com:5432/postgres

# LLM — Gemini (생성 + 임베딩). 모두 서버 전용.
GEMINI_API_KEY=                     # 서버 전용
GEMINI_MODEL=                       # 생성 모델 ID. 기본값 하드코딩 금지 — Phase 1에서 콘솔 확인 후 핀 고정 (제품명 Gemini 3.1 Flash-Lite, 구형 2.0 계열 금지)
GEMINI_EMBEDDING_MODEL=             # 임베딩 모델 ID. Gemini 최신 임베딩 모델 (구형 2.0 계열 금지)

# 네이버 카페 (쓰기 전용 API)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CAFE_CLUB_ID=

# Phase 0 검증 스크립트 전용 (scripts/) — 봇 계정 OAuth 토큰
# 최초 1회 OAuth 동의 후 발급받은 값. 검증이 끝나면 앱은 naver_tokens 테이블에서 관리.
NAVER_ACCESS_TOKEN=
NAVER_REFRESH_TOKEN=
NAVER_TEST_MENUID=                  # 글쓰기 검증용 테스트 게시판 menuid
# 발행 워커 안전 게이트. 'false' 로 명시할 때만 실제 카페에 게시. 그 외(미설정 포함)는 dry-run.
NAVER_PUBLISH_DRY_RUN=true

# 토큰 암호화
TOKEN_ENCRYPTION_KEY=               # refresh token 암호화 (32바이트 권장)

# 이메일
RESEND_API_KEY=

# 크론
CRON_SECRET=                        # pg_net 호출 Authorization 헤더와 일치해야 함

# 백업 (GitHub Actions 시크릿에만 — 로컬 .env 에는 넣지 않음)
BACKUP_ENCRYPTION_KEY=
